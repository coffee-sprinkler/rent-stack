// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  manager
  tenant
}

enum PlanName {
  basic
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  pending
  expired
  cancelled
}

enum PropertyType {
  apartment
  house
  condo
}

enum UnitStatus {
  available
  occupied
  maintenance
}

enum LeaseStatus {
  active
  expired
  terminated
}

enum PaymentStatus {
  pending
  paid
  late
}

enum MaintenancePriority {
  low
  medium
  high
}

enum MaintenanceStatus {
  open
  in_progress
  resolved
}

enum MemberRole {
  admin
  manager
}

enum InviteStatus {
  pending
  accepted
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id      String  @id @default(cuid())
  name    String
  plan_id String?

  logo_url String?
  address  String?
  phone    String?
  email    String?
  website  String?

  users         User[]
  members       OrganizationMember[]
  subscriptions Subscription[]
  properties    Property[]
  tenants       Tenant[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organization_id String
  user_id        String?
  role           MemberRole   @default(manager)
  invite_status  InviteStatus @default(pending)
  invite_token   String?      @unique
  invited_email  String

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([organization_id, invited_email])
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(tenant)

  avatar_url String?
  phone      String?

  pref_min_budget    Decimal?      @db.Decimal(10, 2)
  pref_max_budget    Decimal?      @db.Decimal(10, 2)
  pref_location      String?
  pref_bedrooms      Int?
  pref_property_type PropertyType?

  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])

  org_memberships   OrganizationMember[]
  is_org_admin Boolean @default(false)
  assigned_requests MaintenanceRequest[] @relation("AssignedTo")
  saved_units       SavedUnit[]
  applications      LeaseApplication[]
  payment_methods   PaymentMethod[]

  email_verified   Boolean   @default(false)
  verify_token     String?
  verify_token_exp DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model SavedUnit {
  id      String @id @default(cuid())
  user_id String
  unit_id String

  user User @relation(fields: [user_id], references: [id])
  unit Unit @relation(fields: [unit_id], references: [id])

  saved_at DateTime @default(now())

  @@unique([user_id, unit_id])
}

model LeaseApplication {
  id      String  @id @default(cuid())
  unit_id String
  user_id String
  message String?
  status  String  @default("pending") // pending | approved | rejected

  unit Unit @relation(fields: [unit_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())
}

model Subscription {
  id              String       @id @default(cuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id])

  plan_name           PlanName
  status              SubscriptionStatus @default(trial)
  start_date          DateTime
  end_date            DateTime?
  payment_provider_id String?
}

model Property {
  id              String        @id @default(cuid())
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [id])

  name          String
  province      String?
  city          String?
  barangay      String?
  street        String?
  property_type PropertyType

  units    Unit[]
  expenses Expense[]

  created_at DateTime @default(now())
}

model Unit {
  id          String   @id @default(cuid())
  property_id String
  property    Property @relation(fields: [property_id], references: [id])

  unit_number String
  floor       Int?
  bedrooms    Int
  bathrooms   Int
  rent_amount Decimal    @db.Decimal(10, 2)
  status      UnitStatus @default(available)

  applications         LeaseApplication[]
  images               UnitImage[]
  leases               Lease[]
  maintenance_requests MaintenanceRequest[]
  saved_by             SavedUnit[]
}

model UnitImage {
  id      String @id @default(cuid())
  unit_id String
  unit    Unit   @relation(fields: [unit_id], references: [id])

  url     String
  caption String?
  order   Int     @default(0)

  created_at DateTime @default(now())
}

model PaymentMethod {
  id          String @id @default(cuid())
  user_id     String
  user        User   @relation(fields: [user_id], references: [id])
  label       String
  qr_code_url String

  created_at DateTime @default(now())
}

model Tenant {
  id              String       @id @default(cuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id])

  first_name        String
  last_name         String
  email             String
  phone             String?
  emergency_contact String?

  leases               Lease[]
  maintenance_requests MaintenanceRequest[]
}

model Lease {
  id             String      @id @default(cuid())
  tenant_id      String
  tenant         Tenant      @relation(fields: [tenant_id], references: [id])
  unit_id        String
  unit           Unit        @relation(fields: [unit_id], references: [id])
  start_date     DateTime
  end_date       DateTime
  monthly_rent   Decimal     @db.Decimal(10, 2)
  deposit_amount Decimal     @db.Decimal(10, 2)
  status         LeaseStatus @default(active)

  // New fields
  terminated_at      DateTime?
  termination_reason String?
  document_url       String?
  renewed_from_id    String?
  renewed_from       Lease?  @relation("LeaseRenewals", fields: [renewed_from_id], references: [id], onDelete: SetNull)
  renewals           Lease[] @relation("LeaseRenewals")

  payments Payment[]
}

model Payment {
  id       String @id @default(cuid())
  lease_id String
  lease    Lease  @relation(fields: [lease_id], references: [id])

  amount         Decimal       @db.Decimal(10, 2)
  due_date       DateTime
  paid_date      DateTime?
  status         PaymentStatus @default(pending)
  payment_method String?
}

model MaintenanceRequest {
  id      String @id @default(cuid())
  unit_id String
  unit    Unit   @relation(fields: [unit_id], references: [id])

  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  title       String
  description String
  priority    MaintenancePriority @default(low)
  status      MaintenanceStatus   @default(open)

  assigned_to String?
  assignee    User?   @relation("AssignedTo", fields: [assigned_to], references: [id])

  created_at DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  property_id String
  property    Property @relation(fields: [property_id], references: [id])

  category    String
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  date        DateTime
}